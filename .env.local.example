# === Gemini (WAJIB) ===
# Ambil API key gratis di: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# === Supabase (OPSIONAL — untuk menyimpan history PRD) ===
# Ambil di Supabase Dashboard project kamu -> Settings -> API
#   - Project URL           -> NEXT_PUBLIC_SUPABASE_URL
#   - Project API keys: anon public -> NEXT_PUBLIC_SUPABASE_ANON_KEY
# Kalau dua ini kosong, app tetap jalan tapi fitur riwayat nonaktif.
# anon key MEMANG dipakai di client (aman SELAMA RLS aktif — lihat supabase/schema.sql).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
